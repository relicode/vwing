{
  "name": "vwing",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "license": "Unlicense",
  "description": "V-Wing — an XPilot-style 2D gravity dogfighter built with PixiJS, with a React + MUI shell.",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "dev": "bun ./src/index.html",
    "build": "bun build ./src/index.html --outdir dist --minify --sourcemap=linked --asset-naming=[name]-[hash].[ext]",
    "preview": "bun run scripts/preview.ts",
    "test": "bun test",
    "format": "biome check --write",
    "lint": "FORCE_COLOR=${FORCE_COLOR:-1} concurrently --prefix-colors auto 'bun:lint:*'",
    "lint:biome": "biome check",
    "lint:typescript": "tsc --noEmit",
    "git:feature:finish": "git flow feature finish --no-ff"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9",
    "pixi.js": "^8.19.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3"
  }
}
