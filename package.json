{
  "name": "vwing",
  "version": "0.5.2",
  "private": true,
  "type": "module",
  "license": "Unlicense",
  "description": "V-Wing — an XPilot-style 2D gravity dogfighter built with PixiJS, with a React + MUI shell.",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "dev": "NODE_ENV=development bun --port ${VWING_WEB_PORT:-3110} ./src/index.html",
    "server": "bun run scripts/server.ts",
    "server:dev": "bun --watch scripts/server.ts",
    "dev:all": "concurrently -k --prefix-colors auto -n vwing:web,vwing:srv 'bun:dev' 'bun:server:dev'",
    "redis": "docker compose up -d redis",
    "stack": "docker compose up -d --build",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f",
    "stack:prod": "docker compose -f compose.yaml -f compose.prod.yaml up -d --build",
    "stack:prod:down": "docker compose -f compose.yaml -f compose.prod.yaml down",
    "chrome": "${CHROME_BIN:-google-chrome-stable} --headless=new --remote-debugging-port=${CHROME_PORT:-9222} --user-data-dir=${TMPDIR:-/tmp}/vwing-chrome --no-first-run --no-default-browser-check http://localhost:${VWING_WEB_PORT:-3110}",
    "chrome:visual": "${CHROME_BIN:-google-chrome-stable} --new-window --remote-debugging-port=${CHROME_VISUAL_PORT:-9223} --user-data-dir=${TMPDIR:-/tmp}/vwing-chrome-visual --no-first-run --no-default-browser-check http://localhost:${VWING_WEB_PORT:-3110}",
    "build": "bun run scripts/build.ts",
    "preview": "http-server -c-1 -p ${PORT:-3111} dist",
    "release": "bun run scripts/release.ts",
    "test": "bun test",
    "format": "biome check --write",
    "lint": "FORCE_COLOR=${FORCE_COLOR:-1} concurrently --prefix-colors auto 'bun:lint:*'",
    "lint:biome": "biome check",
    "lint:typescript": "tsc --noEmit",
    "git:feature:finish": "git flow feature finish --no-ff"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9",
    "pixi.js": "^8.19.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "http-server": "^14.1.1",
    "typescript": "^6.0.3"
  }
}
