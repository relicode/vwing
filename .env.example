# Copy to .env and adjust. Compose reads ./.env automatically (it is gitignored).
#
# NOTE: Bun also auto-reads ./.env for `bun run` — do NOT put NODE_ENV=production here. It would
# leak into the dev bundle and make the client dial the wrong origin (`bun run dev` pins
# NODE_ENV=development to defend against this, but keep it out of .env regardless).

# Host Traefik routes the app on. Use a real domain in production; the default
# serves on http://localhost for local `docker compose up`.
APP_DOMAIN=localhost

# Email for Let's Encrypt — REQUIRED for the production TLS stack (compose.prod.yaml, i.e.
# `bun run stack:prod`): uncomment it AND set a real APP_DOMAIN, or the prod config aborts.
# Let's Encrypt also needs inbound :443 reachable. Local `docker compose up` serves plain HTTP.
# ACME_EMAIL=you@example.com
